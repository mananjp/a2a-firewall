# Database — matches docker-compose postgres service
DATABASE_URL=postgresql+asyncpg://a2a:a2apassword@localhost:5432/a2afirewall

# Groq
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SECONDS=2.0
GROQ_CACHE_TTL_SECONDS=3600
GROQ_CACHE_ENABLED=true

# Security
SECRET_KEY=change-this-to-a-256-bit-random-string
API_KEY_SALT=change-this-salt-too

# OpenTelemetry — points at local Jaeger (docker-compose service name "jaeger")
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=a2a-firewall

# App
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173
MAX_PAYLOAD_BYTES=102400
DEFAULT_FAIL_MODE=closed
WORKSPACE_DEFAULT_DENY=true
GROQ_THRESHOLD=0.3
BLOCK_THRESHOLD=0.8
REVIEW_THRESHOLD=0.5